{
	"name": "@quiz/root",
	"license": "UNLICENSED",
	"version": "0.0.0",
	"packageManager": "pnpm@9.4.0",
	"type": "module",
	"scripts": {
		"build": "pnpm --parallel run build",
		"changeset": "changeset",
		"clean": "pnpm --parallel run clean",
		"clean.modules": "find . -name node_modules -type d -prune -print -exec rm -rf {} \\;",
		"dev.react": "pnpm --filter react run dev",
		"lint.check": "pnpm biome check .",
		"lint.write": "pnpm biome check --write .",
		"type.check": "pnpm --parallel run type.check"
	},
	"devDependencies": {
		"@biomejs/biome": "1.9.3",
		"@changesets/changelog-github": "0.6.0",
		"@changesets/cli": "2.30.0",
		"browserslist": "4.28.2",
		"lightningcss": "1.32.0",
		"typescript": "5.9.3"
	},
	"volta": {
		"node": "22.19.0",
		"pnpm": "9.4.0"
	}
}
